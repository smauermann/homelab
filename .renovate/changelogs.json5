{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  packageRules: [
    {
      description: "Changelog URL for 1Password Connect",
      matchPackageNames: ["/1password/"],
      changelogUrl: "https://github.com/1Password/connect/blob/main/CHANGELOG.md",
    },
    {
      description: "Changelog URL for Cloudflared",
      matchPackageNames: ["/cloudflared/"],
      changelogUrl: "https://github.com/cloudflare/cloudflared/blob/master/RELEASE_NOTES",
    },
    {
      description: "Changelog URL for Tailscale Operator",
      matchPackageNames: ["/tailscale/"],
      changelogUrl: "https://tailscale.com/changelog#all",
    },
    {
      description: "Source URL for Longhorn",
      matchDatasources: ["helm"],
      matchPackageNames: ["longhorn"],
      sourceUrl: "https://github.com/longhorn/longhorn",
    },
    {
      description: "Source URL for Talos components",
      matchPackageNames: ["/factory\\.talos\\.dev\\/installer/"],
      sourceUrl: "https://github.com/siderolabs/talos",
    },
    {
      description: "Changelog URL for Kubernetes components",
      matchPackageNames: [
        "/kube-apiserver/",
        "/kube-controller-manager/",
        "/kube-proxy/",
        "/kube-scheduler/",
        "/kubelet/",
      ],
      changelogUrl: "https://github.com/kubernetes/kubernetes/tree/master/CHANGELOG",
    },
  ],
}
